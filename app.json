          "label": {
            "en": "Boiler Power"
          },
          "hint": {
            "en": "The configured total heater power of the single-phase boiler in W. Sunberry uses this value for boiler regulation and percentage calculations."
          },
          "value": 3000,
          "min": 0
        },
        {
          "id": "boiler_1f_regulation_offset",
          "type": "number",
          "label": {
            "en": "Regulation Offset"
          },
          "hint": {
            "en": "Minimum surplus power kept outside boiler heating. For example, with a 300 W offset and 450 W surplus, Sunberry can route about 150 W to the boiler."
