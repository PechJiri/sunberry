  "flow": {
    "triggers": [
      {
        "id": "battery_level_changed",
        "title": {
          "en": "Battery reaches level"
        },
        "titleFormatted": {
          "en": "Battery reaches [[target_level]]%"
        },
        "hint": {
          "en": "Triggers when battery level reaches or crosses your target value between updates."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          },
          {
            "name": "target_level",
            "type": "number",
            "title": {
              "en": "Level"
            },
            "min": 0,
            "max": 100,
            "step": 1,
            "placeholder": {
              "en": "Enter battery level"
            }
          }
        ]
      },
      {
        "id": "battery_max_charging_power_changed",
        "title": {
          "en": "Maximum battery charging power changed"
        },
        "tokens": [
          {
            "name": "power",
            "type": "number",
            "title": {
              "en": "Power"
            },
            "example": 10000
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      },
      {
        "id": "force_charging_started",
        "title": {
          "en": "Battery starts force charging"
        },
        "hint": {
          "en": "Triggers when battery force charging is turned on"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      },
      {
        "id": "force_charging_stopped",
        "title": {
          "en": "Battery stops force charging"
        },
        "hint": {
          "en": "Triggers when battery force charging is turned off"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "battery_level_check",
        "title": {
          "en": "Battery level is above/below specified level"
        },
        "titleFormatted": {
          "en": "Battery level is [[comparison]] [[level]]%"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          },
          {
            "name": "comparison",
            "type": "dropdown",
            "title": {
              "en": "Comparison"
            },
            "values": [
              {
                "id": "below",
                "title": {
                  "en": "below"
                }
              },
              {
                "id": "above",
                "title": {
                  "en": "above"
                }
              }
            ]
          },
          {
            "name": "level",
            "type": "number",
            "title": {
              "en": "Level (%)"
            },
            "placeholder": {
              "en": "Enter battery level"
            },
            "min": 0,
            "max": 100,
            "step": 1
          }
        ]
      },
      {
        "id": "is_battery_discharge_blocked",
        "title": {
          "en": "Battery discharge is !{{blocked|not blocked}}"
        },
        "invertible": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      },
      {
        "id": "is_force_charging",
        "title": {
          "en": "Battery is !{{force charging|not force charging}}"
        },
        "invertible": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "block_battery_discharge",
        "title": {
          "en": "Block battery discharge"
        },
        "handler": "blockBatteryDischarge",
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      },
      {
        "id": "enable_battery_discharge",
        "title": {
          "en": "Enable battery discharge"
        },
        "handler": "enableBatteryDischarge",
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      },
      {
        "id": "turn_off_battery_charging",
        "title": {
          "en": "Turn off force battery charging"
        },
        "handler": "turnOffBatteryCharging",
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          }
        ]
      },
      {
        "id": "turn_on_battery_charging",
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_battery"
          },
          {
            "name": "limit",
            "type": "number",
            "title": {
              "en": "Charging limit (W)"
            },
            "min": 100,
            "max": 10000
          }
        ],
        "title": {
          "en": "Turn on force battery charging with defined W"
        },
        "titleFormatted": {
          "en": "Turn on force battery charging with [[limit]] W"
        }
      },
      {
        "id": "turn_on_smart_contact_with_mode",
        "title": {
          "en": "Turn on Smart Contact with mode"
        },
        "titleFormatted": {
          "en": "Turn on Smart Contact with [[mode]] mode"
        },
        "hint": {
          "en": "Sends the full all-week Smart Contact timer payload using the current start/stop settings, overrides only the selected mode, and then activates Smart Contact."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=sunberry_smart_contact"
          },
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode"
            },
            "values": [
              {
                "id": "battery",
                "title": {
                  "en": "Battery"
                }
              },
              {
                "id": "pv_overflow",
                "title": {
                  "en": "PV overflow"
                }
              },
              {
                "id": "combined",
                "title": {
                  "en": "Combined"
                }
              },
              {
                "id": "off",
                "title": {
                  "en": "Off"
                }
              }
            ]
          }
        ]
      }
    ]
  },
